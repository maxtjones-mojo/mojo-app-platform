# ---- Brivity ----
# Server-side API key. Never expose to a browser.
BRIVITY_API_KEY=
# Override only if your Brivity tenant uses a different base URL.
# Note: the people read API is unversioned (/api), not /api/v2.
BRIVITY_API_BASE=https://api.brivity.com/api

# ---- Google People API (Google Contacts) ----
# OAuth client authorized on the https://www.googleapis.com/auth/contacts scope.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long-lived refresh token for the account whose contacts you are updating
# (e.g. maxtjones@gmail.com). The tool exchanges this for short-lived access tokens.
GOOGLE_REFRESH_TOKEN=
# Optional: paste a short-lived access token to skip the refresh exchange entirely.
GOOGLE_ACCESS_TOKEN=

# ---- Behavior (all overridable via CLI flags) ----
# Match a Brivity person to a Google contact:
#   phone_then_email (default) | email_then_phone | phone_only | email_only
MATCH_STRATEGY=phone_then_email
# Label applied to addresses added in Google Contacts (emails/phones are added unlabeled).
ADDRESS_LABEL=Home
